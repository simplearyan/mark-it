{
  "manifest_version": 3,
  "name": "Markit",
  "version": "1.3.1",
  "description": "Professional, Pixel-Perfect & Universal Annotation Engine (High-Performance 60fps). Optimized for long-form notes and zero-fail injection.",
  "author": "Aryan (simplearyan)",
  "homepage_url": "https://simplearyan.github.io",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle IITM Annotator",
    "default_icon": {
      "16": "icons/icon512.png",
      "48": "icons/icon512.png",
      "128": "icons/icon512.png"
    }
  },
  "icons": {
    "16": "icons/icon512.png",
    "48": "icons/icon512.png",
    "128": "icons/icon512.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "libs/rough.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
